<?xml version="1.0" encoding="utf-8"?>
<!--
    Legacy Auto Backup rules for API 23-30 (superseded by data_extraction_rules.xml on
    API 31+, but both must be present and referenced from the manifest since minSdk is 23).
    Same rationale as data_extraction_rules.xml: don't carry device-specific media URIs,
    screenshots, or prefs across a restore.
-->
<full-backup-content>
    <exclude domain="database" path="watermelon.db" />
    <exclude domain="file" path="screenshots/" />
    <exclude domain="sharedpref" path="watermelon_prefs.xml" />
</full-backup-content>
