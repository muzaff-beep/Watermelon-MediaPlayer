<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView forced to TextureView output so Compose RenderEffects (the VHS shader)
  apply to the video. A default PlayerView uses SurfaceView, which renders on a separate
  hardware surface that RenderEffects cannot touch.
  Location: app/src/main/res/layout/player_view_texture.xml
-->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:use_controller="false"
    app:resize_mode="fit" />
