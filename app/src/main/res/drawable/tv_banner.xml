<?xml version="1.0" encoding="utf-8"?>
<!--
    Android TV banner (required size: 320x180dp — a 16:9 aspect, NOT the square launcher icon).
    The manifest previously pointed android:banner at @mipmap/ic_launcher, which is a square
    adaptive icon; Android TV would either reject it or badly stretch/crop it in the launcher
    row. This is a minimal placeholder built from the app's own brand tokens (Deep Carbon
    background, Watermelon Red wordmark bar) so the manifest reference is at least correctly
    shaped and on-brand until a designed banner asset replaces it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Deep Carbon background — matches WatermelonColors.Palette.DeepCarbon -->
    <path
        android:pathData="M0,0h320v180h-320z"
        android:fillColor="#0D0D0D" />

    <!-- Watermelon Red accent bar — matches WatermelonColors.Palette.WatermelonRed -->
    <path
        android:pathData="M0,150h320v30h-320z"
        android:fillColor="#E63946" />

    <!-- Simple wordmark mark: a rounded "W" glyph substitute (two triangles) in Paper White -->
    <path
        android:pathData="M110,60 L130,120 L145,80 L160,120 L180,60 L168,60 L155,98 L145,70 L135,98 L122,60 Z"
        android:fillColor="#F1FAEE" />
</vector>
